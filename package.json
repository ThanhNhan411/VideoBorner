{
  "name": "product-video-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run web\"",
    "web": "vite --host 0.0.0.0",
    "server": "tsx server/src/index.ts",
    "build": "tsc --noEmit && vite build",
    "create-video": "tsx server/src/cli/createVideo.ts",
    "remotion:preview": "remotion preview remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts ProductVideo storage/videos/manual-render.mp4"
  },
  "dependencies": {
    "@fontsource/be-vietnam-pro": "^5.2.8",
    "@remotion/bundler": "^4.0.482",
    "@remotion/renderer": "^4.0.482",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "edge-tts-universal": "^1.4.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "openai": "^6.44.0",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.482",
    "sharp": "^0.35.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
